{
  "expo": {
    "name": "XO Companion",
    "slug": "xo-companion",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "xo-companion",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xocompanion.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "XO Companion needs microphone access to record voice notes for daily logs.",
        "NSCameraUsageDescription": "XO Companion needs camera access to document jobsite conditions.",
        "NSPhotoLibraryUsageDescription": "XO Companion needs photo library access to attach existing photos.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.xocompanion.app",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "XO Companion needs camera access to document jobsite conditions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e",
          "defaultChannel": "xo-companion",
          "sounds": []
        }
      ],
      "@journeyapps/react-native-quick-sqlite"
    ]
  }
}
