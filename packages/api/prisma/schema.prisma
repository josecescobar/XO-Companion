generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, vector]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  SUPERINTENDENT
  FOREMAN
  FIELD_WORKER
  OWNER_REP
  SAFETY_OFFICER
}

enum DailyLogStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  AMENDED
}

enum WeatherCondition {
  CLEAR
  PARTLY_CLOUDY
  OVERCAST
  RAIN
  HEAVY_RAIN
  SNOW
  SLEET
  FOG
  WIND
  THUNDERSTORM
  EXTREME_HEAT
  EXTREME_COLD
}

enum DelayCause {
  WEATHER
  MATERIAL_SHORTAGE
  EQUIPMENT_FAILURE
  LABOR_SHORTAGE
  DESIGN_CHANGE
  OWNER_DIRECTED
  PERMIT_ISSUE
  INSPECTION_HOLD
  UTILITY_CONFLICT
  SUBCONTRACTOR
  SAFETY_STOP
  OTHER
}

enum EquipmentCondition {
  OPERATIONAL
  NEEDS_MAINTENANCE
  DOWN_FOR_REPAIR
  IDLE
}

enum MaterialCondition {
  GOOD
  DAMAGED
  PARTIAL_DELIVERY
  REJECTED
}

enum VoiceNoteStatus {
  UPLOADING
  TRANSCRIBING
  EXTRACTING
  REVIEW_READY
  PROCESSED
  FAILED
}

enum ReviewAction {
  APPROVED
  REJECTED
  MODIFIED
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RejectionCode {
  WRONG_COUNT
  WRONG_TRADE
  WRONG_DESCRIPTION
  DUPLICATE
  NOT_APPLICABLE
  MISHEARD
  OTHER
}

enum ChunkSourceType {
  DAILY_LOG_SUMMARY
  VOICE_TRANSCRIPT
  MANUAL_NOTE
  DOCUMENT
}

// ─── Document Enums ───

enum DocumentCategory {
  DRAWING
  SPECIFICATION
  SAFETY_MANUAL
  CONTRACT
  SUBMITTAL
  RFI
  CHANGE_ORDER
  PERMIT
  INSPECTION_REPORT
  MEETING_MINUTES
  SCHEDULE
  OTHER
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Compliance Enums ───

enum OshaCaseType {
  DEATH
  DAYS_AWAY
  RESTRICTED
  MEDICAL_TREATMENT
  OTHER_RECORDABLE
}

enum ComplianceDocType {
  CONTRACTOR_LICENSE
  BUSINESS_LICENSE
  GENERAL_LIABILITY
  WORKERS_COMP
  AUTO_INSURANCE
  UMBRELLA_POLICY
  PROFESSIONAL_LIABILITY
  BOND
  EPA_CERTIFICATION
  OSHA_CERTIFICATION
  TRADE_LICENSE
  OTHER
}

enum ComplianceDocStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  RENEWED
  CANCELLED
}

enum SyncStatus {
  SYNCED
  PENDING_UPLOAD
  UPLOAD_FAILED
}

// ─── Risk & Analytics Enums ───

enum RiskAlertType {
  DELAY_PATTERN
  SAFETY_TREND
  BUDGET_VARIANCE
  WORKFORCE_SHORTAGE
  EQUIPMENT_DOWNTIME
  SCHEDULE_SLIP
  WEATHER_RISK
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskAlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

// ─── Task Enums ───

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCategory {
  INSPECTION
  MATERIAL_ORDER
  SUBCONTRACTOR
  CLIENT_COMMUNICATION
  PERMIT
  EQUIPMENT
  SAFETY
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Media Enums ───

enum MediaType {
  PHOTO
  VIDEO
}

// ─── Communication Enums ───

enum CommunicationType {
  EMAIL
  TEXT
  CALL
  RFI
  CHANGE_ORDER
}

enum CommunicationStatus {
  DRAFTING
  DRAFT
  APPROVED
  SENT
  SEND_FAILED
  CANCELLED
}

enum CommunicationUrgency {
  LOW
  NORMAL
  HIGH
}

// ─── Inspection Enums ───

enum InspectionType {
  DRAWING_COMPARISON
  SPEC_COMPLIANCE
  SAFETY_CHECK
  QUALITY_CHECK
  PROGRESS_PHOTO
  GENERAL
}

enum InspectionResult {
  PENDING
  PROCESSING
  PASS
  FAIL
  NEEDS_ATTENTION
  INCONCLUSIVE
}

// ─────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  projects            Project[]
  glossaryTerms       GlossaryTerm[]
  oshaIncidents       OshaIncident[]
  complianceDocuments ComplianceDocument[]
  trainingRecords     TrainingRecord[]
  riskAlerts          RiskAlert[]
  media               Media[]
  projectDocuments    ProjectDocument[]
  inspections         Inspection[]
  communications      Communication[]
  syncConflictLogs    SyncConflictLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String   @unique
  passwordHash   String   @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  role           Role
  isActive       Boolean  @default(true) @map("is_active")
  organizationId String   @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  projectMembers ProjectMember[]
  refreshTokens  RefreshToken[]
  dailyLogs      DailyLog[]      @relation("CreatedByUser")
  voiceNotes     VoiceNote[]
  signatures     Signature[]
  reviewActions  ReviewEntry[]
  createdTasks       Task[]          @relation("CreatedTasks")
  uploadedMedia      Media[]         @relation("UploadedMedia")
  uploadedDocuments  ProjectDocument[] @relation("UploadedDocuments")
  createdInspections      Inspection[]     @relation("CreatedInspections")
  reviewedInspections     Inspection[]     @relation("ReviewedInspections")
  deviceTokens            DeviceToken[]
  createdCommunications   Communication[]  @relation("CreatedCommunications")
  approvedCommunications  Communication[]  @relation("ApprovedCommunications")
  employeeTrainingRecords TrainingRecord[] @relation("EmployeeTraining")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id") @db.Uuid
  family    String
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model Project {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  zipCode        String?   @map("zip_code")
  organizationId String    @map("organization_id") @db.Uuid
  isActive       Boolean   @default(true) @map("is_active")
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  members        ProjectMember[]
  dailyLogs      DailyLog[]
  documentChunks DocumentChunk[]
  oshaIncidents       OshaIncident[]
  complianceDocuments ComplianceDocument[]
  trainingRecords     TrainingRecord[]
  riskAlerts          RiskAlert[]
  tasks               Task[]
  media               Media[]
  documents           ProjectDocument[]
  inspections         Inspection[]
  communications      Communication[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

// ─────────────────────────────────────────────
// DAILY LOG
// ─────────────────────────────────────────────

model DailyLog {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String         @map("project_id") @db.Uuid
  logDate      DateTime       @map("log_date") @db.Date
  status       DailyLogStatus @default(DRAFT)
  createdById  String         @map("created_by_id") @db.Uuid
  reportNumber Int?           @map("report_number")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  project       Project              @relation(fields: [projectId], references: [id])
  createdBy     User                 @relation("CreatedByUser", fields: [createdById], references: [id])
  weather       WeatherEntry?
  workforce     WorkforceEntry[]
  equipment     EquipmentEntry[]
  workCompleted WorkCompletedEntry[]
  materials     MaterialEntry[]
  safety        SafetyEntry?
  delays        DelayEntry[]
  voiceNotes    VoiceNote[]
  signatures    Signature[]
  reviewEntries ReviewEntry[]
  tasks            Task[]
  media            Media[]
  inspections      Inspection[]
  communications   Communication[]

  @@unique([projectId, logDate])
  @@index([projectId, status])
  @@index([createdById])
  @@index([logDate])
  @@map("daily_logs")
}

// ─── Weather Block ───

model WeatherEntry {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId    String             @unique @map("daily_log_id") @db.Uuid
  conditions    WeatherCondition[]
  tempHigh      Float?             @map("temp_high")
  tempLow       Float?             @map("temp_low")
  precipitation String?
  windSpeed     Float?             @map("wind_speed")
  windDirection String?            @map("wind_direction")
  humidity      Float?
  delayMinutes  Int                @default(0) @map("delay_minutes")
  aiGenerated        Boolean            @default(false) @map("ai_generated")
  aiConfidence       Float?             @map("ai_confidence")
  aiConfidenceReason String?            @map("ai_confidence_reason")
  reviewStatus       ReviewStatus?      @map("review_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@map("weather_entries")
}

// ─── Workforce Array ───

model WorkforceEntry {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId    String   @map("daily_log_id") @db.Uuid
  trade         String
  company       String
  workerCount   Int      @map("worker_count")
  hoursWorked   Float    @map("hours_worked")
  overtimeHours Float    @default(0) @map("overtime_hours")
  foreman       String?
  aiGenerated        Boolean       @default(false) @map("ai_generated")
  aiConfidence       Float?        @map("ai_confidence")
  aiConfidenceReason String?       @map("ai_confidence_reason")
  reviewStatus       ReviewStatus? @map("review_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("workforce_entries")
}

// ─── Equipment Array ───

model EquipmentEntry {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId     String             @map("daily_log_id") @db.Uuid
  equipmentType  String             @map("equipment_type")
  equipmentId    String?            @map("equipment_id")
  operatingHours Float              @map("operating_hours")
  idleHours      Float              @default(0) @map("idle_hours")
  condition      EquipmentCondition
  notes          String?
  aiGenerated        Boolean            @default(false) @map("ai_generated")
  aiConfidence       Float?             @map("ai_confidence")
  aiConfidenceReason String?            @map("ai_confidence_reason")
  reviewStatus       ReviewStatus?      @map("review_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("equipment_entries")
}

// ─── Work Completed Array ───

model WorkCompletedEntry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId      String   @map("daily_log_id") @db.Uuid
  location        String
  csiCode         String?  @map("csi_code")
  csiDescription  String?  @map("csi_description")
  description     String
  percentComplete Float?   @map("percent_complete")
  quantity        Float?
  unit            String?
  aiGenerated        Boolean       @default(false) @map("ai_generated")
  aiConfidence       Float?        @map("ai_confidence")
  aiConfidenceReason String?       @map("ai_confidence_reason")
  reviewStatus       ReviewStatus? @map("review_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([csiCode])
  @@map("work_completed_entries")
}

// ─── Materials Delivered Array ───

model MaterialEntry {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId   String            @map("daily_log_id") @db.Uuid
  material     String
  quantity     Float?
  unit         String?
  supplier     String?
  ticketNumber String?           @map("ticket_number")
  condition    MaterialCondition @default(GOOD)
  aiGenerated        Boolean           @default(false) @map("ai_generated")
  aiConfidence       Float?            @map("ai_confidence")
  aiConfidenceReason String?           @map("ai_confidence_reason")
  reviewStatus       ReviewStatus?     @map("review_status")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("material_entries")
}

// ─── Safety Block ───

model SafetyEntry {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId     String   @unique @map("daily_log_id") @db.Uuid
  toolboxTalks   String[] @map("toolbox_talks")
  inspections    String[]
  incidents      String[]
  oshaRecordable Boolean  @default(false) @map("osha_recordable")
  nearMisses     Int      @default(0) @map("near_misses")
  firstAidCases  Int      @default(0) @map("first_aid_cases")
  notes          String?
  aiGenerated        Boolean       @default(false) @map("ai_generated")
  aiConfidence       Float?        @map("ai_confidence")
  aiConfidenceReason String?       @map("ai_confidence_reason")
  reviewStatus       ReviewStatus? @map("review_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@map("safety_entries")
}

// ─── Delays Array ───

model DelayEntry {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId      String     @map("daily_log_id") @db.Uuid
  cause           DelayCause
  description     String
  durationMinutes Int        @map("duration_minutes")
  impactedTrades  String[]   @map("impacted_trades")
  aiGenerated        Boolean       @default(false) @map("ai_generated")
  aiConfidence       Float?        @map("ai_confidence")
  aiConfidenceReason String?       @map("ai_confidence_reason")
  reviewStatus       ReviewStatus? @map("review_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("delay_entries")
}

// ─── Voice Notes Array ───

model VoiceNote {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId      String          @map("daily_log_id") @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  audioUrl        String          @map("audio_url")
  audioSize       Int?            @map("audio_size")
  durationSeconds Int?            @map("duration_seconds")
  mimeType        String          @default("audio/webm") @map("mime_type")
  transcript      String?
  status          VoiceNoteStatus @default(UPLOADING)
  aiProcessed     Boolean         @default(false) @map("ai_processed")
  extractedData   Json?           @map("extracted_data")
  processingError String?         @map("processing_error")
  assemblyaiId    String?         @map("assemblyai_id")
  syncStatus      SyncStatus      @default(SYNCED) @map("sync_status")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([dailyLogId])
  @@index([userId])
  @@index([status])
  @@index([syncStatus])
  @@map("voice_notes")
}

// ─── Signatures Array ───

model Signature {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId    String   @map("daily_log_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  role          Role
  signatureData String   @map("signature_data")
  signedAt      DateTime @default(now()) @map("signed_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([dailyLogId, userId])
  @@index([dailyLogId])
  @@map("signatures")
}

// ─── HITL Review Entries ───

model ReviewEntry {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLogId    String       @map("daily_log_id") @db.Uuid
  reviewerId    String       @map("reviewer_id") @db.Uuid
  entityType    String       @map("entity_type")
  entityId      String       @map("entity_id") @db.Uuid
  fieldName     String?      @map("field_name")
  action        ReviewAction
  reasonCode    RejectionCode? @map("reason_code")
  previousValue Json?        @map("previous_value")
  newValue      Json?        @map("new_value")
  comment       String?
  createdAt     DateTime     @default(now()) @map("created_at")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id])

  @@index([dailyLogId])
  @@index([reviewerId])
  @@index([entityType, entityId])
  @@map("review_entries")
}

// ─────────────────────────────────────────────
// GLOSSARY
// ─────────────────────────────────────────────

enum GlossaryCategory {
  TRADE
  EQUIPMENT
  MATERIAL
  ABBREVIATION
  UNIT
  OTHER
}

model GlossaryTerm {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  term           String
  aliases        String[]
  category       GlossaryCategory
  csiCode        String?          @map("csi_code")
  active         Boolean          @default(true)
  source         String           @default("manual")
  usageCount     Int              @default(0) @map("usage_count")
  organizationId String           @map("organization_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([term, organizationId])
  @@index([organizationId])
  @@index([category])
  @@map("glossary_terms")
}

// ─────────────────────────────────────────────
// DOCUMENT CHUNKS (RAG / Project Memory)
// ─────────────────────────────────────────────

model DocumentChunk {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  sourceType ChunkSourceType @map("source_type")
  sourceId   String          @map("source_id") @db.Uuid
  chunkIndex Int             @map("chunk_index")
  content    String
  tokenCount Int             @map("token_count")
  embedding  Unsupported("vector(1536)")?
  embedded   Boolean         @default(false)
  sourceDate DateTime        @map("source_date") @db.Date
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType, sourceId])
  @@index([sourceDate])
  @@index([embedded])
  @@map("document_chunks")
}

// ─────────────────────────────────────────────
// COMPLIANCE
// ─────────────────────────────────────────────

model OshaIncident {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String        @map("organization_id") @db.Uuid
  projectId           String        @map("project_id") @db.Uuid

  // Employee info
  employeeName        String        @map("employee_name")
  employeeJobTitle    String?       @map("employee_job_title")
  employeeDateOfBirth DateTime?     @map("employee_date_of_birth")
  employeeHireDate    DateTime?     @map("employee_hire_date")

  // Incident details
  incidentDate        DateTime      @map("incident_date")
  incidentTime        String?       @map("incident_time")
  location            String?
  description         String
  injuryType          String?       @map("injury_type")
  bodyPart            String?       @map("body_part")
  objectOrSubstance   String?       @map("object_or_substance")

  // Outcome
  deathDate           DateTime?     @map("death_date")
  daysAwayFromWork    Int?          @map("days_away_from_work")
  daysRestricted      Int?          @map("days_restricted")

  // Classification
  isRecordable        Boolean       @default(false) @map("is_recordable")
  caseType            OshaCaseType? @map("case_type")

  // Linking
  dailyLogId          String?       @map("daily_log_id") @db.Uuid
  safetyEntryId       String?       @map("safety_entry_id") @db.Uuid

  // Status
  status              String        @default("DRAFT")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([incidentDate])
  @@map("osha_incidents")
}

model ComplianceDocument {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid

  documentType     ComplianceDocType @map("document_type")
  name             String
  description      String?

  // Dates
  issueDate        DateTime?         @map("issue_date")
  expirationDate   DateTime?         @map("expiration_date")

  // Status
  status           ComplianceDocStatus @default(ACTIVE)

  // Alerts
  alertDays        Int[]             @default([90, 60, 30, 14]) @map("alert_days")
  lastAlertSent    DateTime?         @map("last_alert_sent")

  // Metadata
  licenseNumber    String?           @map("license_number")
  issuingAuthority String?           @map("issuing_authority")
  state            String?

  // File reference
  fileUrl          String?           @map("file_url")

  // Optional project link
  projectId        String?           @map("project_id") @db.Uuid

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([expirationDate])
  @@index([status])
  @@map("compliance_documents")
}

model TrainingRecord {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid

  employeeName    String   @map("employee_name")
  employeeId      String?  @map("employee_id") @db.Uuid

  trainingType    String   @map("training_type")
  topic           String
  description     String?

  completedDate   DateTime @map("completed_date")
  expirationDate  DateTime? @map("expiration_date")

  trainer         String?
  certificationId String?  @map("certification_id")

  // Link to daily log toolbox talk
  dailyLogId      String?  @map("daily_log_id") @db.Uuid

  // Optional project link
  projectId       String?  @map("project_id") @db.Uuid

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  employee     User?        @relation("EmployeeTraining", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeName])
  @@index([expirationDate])
  @@map("training_records")
}

// ─────────────────────────────────────────────
// SYNC CONFLICT LOG
// ─────────────────────────────────────────────

model SyncConflictLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  table           String
  recordId        String   @map("record_id") @db.Uuid
  clientData      Json     @map("client_data")
  serverData      Json     @map("server_data")
  clientTimestamp  DateTime @map("client_timestamp")
  serverTimestamp  DateTime @map("server_timestamp")
  resolution      String   @default("SERVER_WINS")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([table, recordId])
  @@map("sync_conflict_logs")
}

// ─────────────────────────────────────────────
// RISK ALERTS
// ─────────────────────────────────────────────

model RiskAlert {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String          @map("organization_id") @db.Uuid
  projectId       String          @map("project_id") @db.Uuid

  alertType       RiskAlertType   @map("alert_type")
  severity        RiskSeverity
  title           String
  description     String

  // Source data
  sourceData      Json?           @map("source_data")

  // Status
  status          RiskAlertStatus @default(ACTIVE)
  acknowledgedBy  String?         @map("acknowledged_by") @db.Uuid
  acknowledgedAt  DateTime?       @map("acknowledged_at")
  resolvedAt      DateTime?       @map("resolved_at")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id])
  project         Project         @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([alertType])
  @@index([status])
  @@index([severity])
  @@map("risk_alerts")
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────

model Task {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String       @map("project_id") @db.Uuid
  dailyLogId    String?      @map("daily_log_id") @db.Uuid
  voiceNoteId   String?      @map("voice_note_id") @db.Uuid

  description   String
  assignee      String?
  dueDate       DateTime?    @map("due_date")
  priority      TaskPriority @default(MEDIUM)
  category      TaskCategory @default(OTHER)
  status        TaskStatus   @default(PENDING)

  aiGenerated   Boolean      @default(true) @map("ai_generated")
  aiConfidence  Float?       @map("ai_confidence")

  createdById   String       @map("created_by_id") @db.Uuid
  completedAt   DateTime?    @map("completed_at")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLog      DailyLog?    @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  createdBy     User         @relation("CreatedTasks", fields: [createdById], references: [id])

  @@index([projectId, status])
  @@index([assignee])
  @@index([dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────
// MEDIA
// ─────────────────────────────────────────────

model Media {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  dailyLogId     String?   @map("daily_log_id") @db.Uuid
  voiceNoteId    String?   @map("voice_note_id") @db.Uuid
  incidentId     String?   @map("incident_id") @db.Uuid

  type           MediaType
  fileName       String    @map("file_name")
  filePath       String    @map("file_path")
  mimeType       String    @map("mime_type")
  fileSize       Int       @map("file_size")
  width          Int?
  height         Int?
  durationMs     Int?      @map("duration_ms")
  caption        String?
  thumbnailPath  String?   @map("thumbnail_path")

  uploadedById   String    @map("uploaded_by_id") @db.Uuid

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLog       DailyLog?    @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  uploadedBy     User         @relation("UploadedMedia", fields: [uploadedById], references: [id])
  inspections    Inspection[]

  @@index([projectId])
  @@index([dailyLogId])
  @@index([incidentId])
  @@map("media")
}

// ─────────────────────────────────────────────
// PROJECT DOCUMENTS
// ─────────────────────────────────────────────

model ProjectDocument {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  projectId       String             @map("project_id") @db.Uuid
  uploadedById    String             @map("uploaded_by_id") @db.Uuid

  title           String
  description     String?
  fileName        String             @map("file_name")
  filePath        String             @map("file_path")
  mimeType        String             @map("mime_type")
  fileSize        Int                @map("file_size")
  pageCount       Int?               @map("page_count")
  category        DocumentCategory
  status          DocumentStatus     @default(PENDING)

  chunksCreated   Int                @default(0) @map("chunks_created")
  embedded        Boolean            @default(false)
  processingError String?            @map("processing_error")
  processedAt     DateTime?          @map("processed_at")

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  organization    Organization       @relation(fields: [organizationId], references: [id])
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy      User               @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  inspections     Inspection[]

  @@index([projectId, category])
  @@index([projectId, status])
  @@map("project_documents")
}

// ─────────────────────────────────────────────
// INSPECTIONS
// ─────────────────────────────────────────────

model Inspection {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  projectId       String             @map("project_id") @db.Uuid
  dailyLogId      String?            @map("daily_log_id") @db.Uuid
  mediaId         String             @map("media_id") @db.Uuid
  documentId      String?            @map("document_id") @db.Uuid

  title           String
  description     String?
  inspectionType  InspectionType     @map("inspection_type")
  status          InspectionResult   @default(PENDING)

  aiAnalysis      String?            @map("ai_analysis") @db.Text
  aiFindings      Json?              @map("ai_findings")
  aiOverallScore  Float?             @map("ai_overall_score")
  aiProcessedAt   DateTime?          @map("ai_processed_at")
  processingError String?            @map("processing_error")

  ragContextUsed  Json?              @map("rag_context_used")
  tokensUsed      Int?               @map("tokens_used")

  reviewedById    String?            @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?          @map("reviewed_at")
  reviewNotes     String?            @map("review_notes")

  createdById     String             @map("created_by_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  organization    Organization       @relation(fields: [organizationId], references: [id])
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLog        DailyLog?          @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  media           Media              @relation(fields: [mediaId], references: [id])
  document        ProjectDocument?   @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdBy       User               @relation("CreatedInspections", fields: [createdById], references: [id])
  reviewedBy      User?              @relation("ReviewedInspections", fields: [reviewedById], references: [id])

  @@index([projectId, status])
  @@index([projectId, inspectionType])
  @@index([mediaId])
  @@map("inspections")
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

model Communication {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  projectId       String                @map("project_id") @db.Uuid
  dailyLogId      String?               @map("daily_log_id") @db.Uuid
  voiceNoteId     String?               @map("voice_note_id") @db.Uuid

  type            CommunicationType
  status          CommunicationStatus   @default(DRAFTING)
  urgency         CommunicationUrgency  @default(NORMAL)

  recipient       String
  recipientEmail  String?               @map("recipient_email")
  recipientPhone  String?               @map("recipient_phone")
  subject         String
  body            String?               @db.Text
  context         String?               @db.Text

  aiGenerated     Boolean               @default(true) @map("ai_generated")
  aiConfidence    Float?                @map("ai_confidence")
  aiDraftedAt     DateTime?             @map("ai_drafted_at")
  processingError String?               @map("processing_error")
  tokensUsed      Int?                  @map("tokens_used")

  editedBody      String?               @map("edited_body") @db.Text
  approvedById    String?               @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?             @map("approved_at")
  sentAt          DateTime?             @map("sent_at")
  externalMessageId String?             @map("external_message_id")

  createdById     String                @map("created_by_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  organization    Organization          @relation(fields: [organizationId], references: [id])
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLog        DailyLog?             @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  createdBy       User                  @relation("CreatedCommunications", fields: [createdById], references: [id])
  approvedBy      User?                 @relation("ApprovedCommunications", fields: [approvedById], references: [id])

  @@index([projectId, status])
  @@index([projectId, type])
  @@index([createdById])
  @@map("communications")
}

// ─────────────────────────────────────────────
// DEVICE TOKENS (Push Notifications)
// ─────────────────────────────────────────────

model DeviceToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  token       String   @unique
  platform    String   @default("ios")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}
