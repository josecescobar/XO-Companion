# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://xo_user:xo_local_password@localhost:5432/xo_companion

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Auth
JWT_ACCESS_SECRET=change-this-to-a-random-32-char-string-for-access
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-this-to-a-random-32-char-string-for-refresh
JWT_REFRESH_EXPIRATION=7d

# AssemblyAI
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
# Also used for embeddings (text-embedding-3-small) in Project Memory RAG.
# If not set or out of credits, chunks are stored without embeddings.
# Call POST /projects/:id/memory/re-embed after adding credits.
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

# AI Configuration
AI_PRIMARY_MODEL=claude-sonnet-4-20250514
AI_FALLBACK_MODEL=gpt-4o-mini
AI_CONFIDENCE_THRESHOLD=0.85

# File Upload
UPLOAD_DIR=./uploads
MAX_AUDIO_FILE_SIZE=52428800

# PowerSync
POWERSYNC_URL=https://YOUR_INSTANCE.powersync.journeyapps.com
POWERSYNC_PRIVATE_KEY=  # from PowerSync dashboard; falls back to JWT_ACCESS_SECRET if not set

# CORS
CORS_ORIGIN=http://localhost:3001
